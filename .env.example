# .env.example

# Required environment variables

# The port the server will run on (default: 3000)
PORT=3000

# The database connection string for MongoDB
MONGODB_URI="mongodb://username:password@localhost:27017/mydatabase"

# The secret key for session management
SESSION_SECRET="your_secret_key"

# Optional environment variables

# URL for the bot to connect to the messaging service
MESSAGING_SERVICE_URL="https://api.messaging.com"

# Log level for debugging information (default: info)
LOG_LEVEL="info"

# Timeout for API requests (in milliseconds)
API_TIMEOUT=5000

# Enable or disable the debug mode (true/false)
DEBUG=false

# API keys for third-party services

# Google Maps API key
GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# Stripe API key for payments
STRIPE_API_KEY="your_stripe_api_key"

# Other service credentials can be added below according to your needs.